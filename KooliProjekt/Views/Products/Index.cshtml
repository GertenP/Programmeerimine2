@model IEnumerable<KooliProjekt.Data.Product>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>

<h2>Categories:</h2>
<ul>
    @if (ViewBag.Categories != null)
    {
        foreach (var category in ViewBag.Categories as List<KooliProjekt.Data.Category>)
        {
            <li>@category.Name</li>
        }
    }
    else
    {
        <li>No categories available</li>
    }
</ul>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.First().Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.First().Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.First().Price)
            </th>
            <th>
                Category
            </th>
            <th>
                @Html.DisplayNameFor(model => model.First().Discount)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Description)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Price)€
                </td>
                <td>

                    @{
                        foreach (var category in ViewBag.Categories as List<KooliProjekt.Data.Category>)
                        {
                            if (item.CategoryId == category.Id){
                                @Html.DisplayFor(modelItem => category.Name);
                            }
                        }
                    }
                </td>
                <td>
                    @{
                        if (item.Discount == 0){
                        
                            <p>Puudub</p>

                        } else 
                        {
                        <p>@Html.DisplayFor(modelItem => item.Discount)%</p>;
                        }
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
